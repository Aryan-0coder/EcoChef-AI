    "from ibm_watsonx_ai import Credentials\n",
    "from dotenv import load_dotenv\n",
    "import os\n",
    "\n",
    "load_dotenv()\n",
    "\n",
    "credentials = Credentials(\n",
    "    url=os.getenv(\"URL\"),\n",
    "    api_key=os.getenv(\"API_KEY\")\n",
    ")\n",
    "\n",
    "print(\"Connection object created successfully\")"
   ]
